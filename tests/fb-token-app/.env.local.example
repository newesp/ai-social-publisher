# 從 https://developers.facebook.com/apps 你的 App -> Settings -> Basic 取得
FB_APP_ID=你的App ID
FB_APP_SECRET=你的App Secret

# 必須和 Meta App Dashboard -> Facebook Login -> Settings ->
# Valid OAuth Redirect URIs 裡登記的網址完全一致(含 http/https、路徑)
# 本機測試範例:
FB_REDIRECT_URI=http://localhost:3000/api/facebook/callback
# 部署到 Vercel 後改成:
# FB_REDIRECT_URI=https://your-app.vercel.app/api/facebook/callback
