NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Required: demo permits non-empty Google emails; production requires ALLOWED_GOOGLE_EMAILS.
AUTH_MODE=demo
ALLOWED_GOOGLE_EMAILS=
ADMIN_EMAILS=admin@example.com

GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

TURSO_DATABASE_URL=libsql://example.turso.io
TURSO_AUTH_TOKEN=

IMGUR_CLIENT_ID=

# Server-only Meta OAuth App integration credentials. Each user connects their own Page.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/platform-connections/meta/callback

META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

LINE_CHANNEL_ACCESS_TOKEN=
CRON_SECRET=replace-with-random-secret
SETTINGS_ENCRYPTION_KEY=replace-with-32-byte-base64-key
DISABLE_AUTH_FOR_LOCAL_DEV=false
